rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Projects — only the owner can read/write
    match /projects/{projectId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // Files sub-collection — inherits same ownership rule
      match /files/{fileId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
      }
    }

    // Collaboration presence/cursors — any authenticated user can read,
    // but only write their own presence doc (uid == docId)
    match /presence/{projectId}/users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Collab sessions — project owner can write; any authenticated user can read
    match /collabSessions/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
    }

    // Chat messages — any authenticated user can read/write
    match /chat/{projectId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
