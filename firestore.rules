rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(projectId) {
      return request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.userId == request.auth.uid;
    }

    function isCollabActive(projectId) {
      let session = get(/databases/$(database)/documents/projects/$(projectId)/collab/session);
      return session.data.active == true;
    }

    // Projects — only the owner can read/write the project document itself
    match /projects/{projectId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // Files — owner always; collaborators can read/write when session is active
      match /files/{fileId} {
        allow read, write: if request.auth != null && isOwner(projectId);
        allow read, write: if request.auth != null && isCollabActive(projectId);
      }

      // Presence — any authed user can write their own doc, anyone can read
      match /presence/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Collab session — owner writes, anyone authenticated reads
      match /collab/session {
        allow read: if request.auth != null;
        allow write: if request.auth != null && isOwner(projectId);
      }

      // Chat — any authenticated user in a collab session can send/receive
      match /chat/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
